<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/music_widget"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="16dp"
    android:paddingTop="6dp"
    android:paddingEnd="16dp"
    android:paddingBottom="4dp"
    android:background="@android:color/transparent"
    android:visibility="gone">

    <FrameLayout
        android:id="@+id/music_widget_border"
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/terminal_border"
        android:padding="6dp">

        <ohi.andre.consolelauncher.tuils.MusicVisualizerView
            android:id="@+id/music_visualizer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingTop="14dp"
            android:paddingEnd="10dp"
            android:paddingBottom="2dp">

            <ohi.andre.consolelauncher.tuils.OutlineTextView
                android:id="@+id/music_song_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Now Playing: -"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ohi.andre.consolelauncher.tuils.OutlineTextView
                android:id="@+id/music_singer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Singer      : -"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/music_prev"
                    android:layout_width="60dp"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="PREV"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/music_play_pause"
                    android:layout_width="80dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:gravity="center"
                    android:text="PLAY/PAUSE"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/music_next"
                    android:layout_width="60dp"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="NEXT"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/music_widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/music_widget_border"
        android:layout_alignStart="@id/music_widget_border"
        android:layout_marginTop="-10dp"
        android:layout_marginStart="24dp"
        android:background="@drawable/apps_drawer_header_border"
        android:fontFamily="monospace"
        android:gravity="center"
        android:minWidth="170dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="NOW PLAYING"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

</RelativeLayout>
