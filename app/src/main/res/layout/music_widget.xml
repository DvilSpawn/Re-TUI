<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/music_widget"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="16dp"
    android:paddingTop="8dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp"
    android:background="@android:color/transparent">

    <FrameLayout
        android:id="@+id/music_widget_border"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/terminal_border"
        android:padding="8dp">

        <ohi.andre.consolelauncher.tuils.MusicVisualizerView
            android:id="@+id/music_visualizer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingTop="18dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp">

            <ohi.andre.consolelauncher.tuils.OutlineTextView
                android:id="@+id/music_song_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="2"
                android:text="Now Playing: -"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ohi.andre.consolelauncher.tuils.OutlineTextView
                android:id="@+id/music_singer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:text="Singer      : -"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/music_widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/music_widget_border"
        android:layout_alignStart="@id/music_widget_border"
        android:layout_marginTop="-10dp"
        android:layout_marginStart="24dp"
        android:background="@drawable/apps_drawer_header_border"
        android:fontFamily="monospace"
        android:gravity="center"
        android:minWidth="170dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="NOW PLAYING"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

</RelativeLayout>
