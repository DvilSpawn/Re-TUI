<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/lockdown_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="20dp">

    <ImageView
        android:id="@+id/lockdown_title"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:adjustViewBounds="true"
        android:contentDescription="LOCKDOWN"
        android:scaleType="fitCenter"
        android:src="@drawable/lockdown_wordmark" />

    <TextView
        android:id="@+id/lockdown_reason"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Focus mode"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/lockdown_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="25:00"
        android:textSize="64sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/lockdown_wallet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:text="Credits: 1000 | Keys: 0"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/lockdown_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/lockdown_skip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="SKIP LOCKDOWN  -500 CREDITS"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lockdown_key"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="USE BREACH KEY"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lockdown_breach"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="EMERGENCY BREACH"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
