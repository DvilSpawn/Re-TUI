<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/file_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clickable="true"
    android:focusable="true"
    android:paddingStart="22dp"
    android:paddingTop="22dp"
    android:paddingEnd="22dp"
    android:paddingBottom="4dp"
    android:visibility="gone">

    <LinearLayout
        android:id="@+id/file_window_border"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="2dp"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="30dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/file_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textSize="12sp" />

        <ScrollView
            android:id="@+id/file_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:fillViewport="true">

                <TextView
                    android:id="@+id/file_output"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textIsSelectable="true"
                    android:textSize="13sp" />
        </ScrollView>

        <LinearLayout
            android:id="@+id/file_input_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

                <TextView
                    android:id="@+id/file_prefix"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$ "
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/file_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/hint_file_console_input"
                    android:imeOptions="actionGo|flagNoFullscreen"
                    android:importantForAutofill="no"
                    android:singleLine="true"
                    android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/file_tools"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="2dp"
            android:paddingEnd="2dp">

                <TextView
                    android:id="@+id/file_refresh"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="REFRESH"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/file_up"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="UP"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/file_open"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="OPEN"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/file_paste"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="PASTE"
                    android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/file_window_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="44dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:minWidth="160dp"
        android:paddingStart="12dp"
        android:paddingTop="2dp"
        android:paddingEnd="12dp"
        android:paddingBottom="2dp"
        android:text="FILES"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/file_close"
        android:layout_width="48dp"
        android:layout_height="36dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="X"
        android:textSize="15sp" />

</FrameLayout>
