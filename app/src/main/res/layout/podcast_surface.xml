<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/podcast_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clickable="true"
    android:focusable="true"
    android:paddingStart="8dp"
    android:paddingTop="0dp"
    android:paddingEnd="8dp"
    android:paddingBottom="4dp"
    android:visibility="gone">

    <LinearLayout
        android:id="@+id/podcast_window_border"
        android:layout_width="match_parent"
        android:layout_height="620dp"
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="28dp"
        android:paddingEnd="10dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:id="@+id/podcast_tabs"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/podcast_tab_shows"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="SHOWS"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/podcast_play_show"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="RECENTS"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/podcast_add"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="ADD"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/podcast_refresh"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="REFRESH"
                android:textSize="11sp" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/podcast_content_panel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingStart="8dp"
            android:paddingTop="12dp"
            android:paddingEnd="8dp"
            android:paddingBottom="8dp">

            <ScrollView
                android:id="@+id/podcast_scroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:paddingBottom="52dp">

                <LinearLayout
                    android:id="@+id/podcast_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>

            <TextView
                android:id="@+id/podcast_content_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_marginStart="12dp"
                android:layout_marginTop="-12dp"
                android:contentDescription="Back to shows"
                android:gravity="center"
                android:minWidth="44dp"
                android:paddingStart="8dp"
                android:paddingTop="1dp"
                android:paddingEnd="8dp"
                android:paddingBottom="1dp"
                android:text="[&lt;]"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/podcast_content_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_marginStart="12dp"
                android:layout_marginTop="-12dp"
                android:gravity="center"
                android:minWidth="104dp"
                android:paddingStart="10dp"
                android:paddingTop="1dp"
                android:paddingEnd="10dp"
                android:paddingBottom="1dp"
                android:text="SHOWS"
                android:textAllCaps="true"
                android:textSize="12sp"
                android:visibility="visible" />

            <LinearLayout
                android:id="@+id/podcast_pane_actions"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="10dp"
                android:gravity="center"
                android:orientation="horizontal" />

            <LinearLayout
                android:id="@+id/podcast_player_controls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="10dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/podcast_player_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="0:00"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/podcast_player_seek"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:enabled="false"
                    android:max="100"
                    android:progress="0" />

                <LinearLayout
                    android:id="@+id/podcast_player_transport"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/podcast_player_prev"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="[ PREV ]"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/podcast_player_rewind"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="[ -30 ]"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/podcast_player_play"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="[ PLAY ]"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/podcast_player_forward"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="[ +30 ]"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/podcast_player_next"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="[ NEXT ]"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/podcast_now_playing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:padding="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/podcast_artwork"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:contentDescription="Podcast artwork"
                    android:scaleType="centerCrop"
                    android:src="@mipmap/ic_launcher" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/podcast_now_meta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Add a feed, then play a show."
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/podcast_now_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="No podcast playing"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/podcast_now_progress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="0:00"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <SeekBar
                android:id="@+id/podcast_seek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:enabled="false"
                android:max="100"
                android:progress="0" />

            <LinearLayout
                android:id="@+id/podcast_transport"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/podcast_prev"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="[ PREV ]"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/podcast_rewind"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="[ -30 ]"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/podcast_play"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="[ PLAY ]"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/podcast_forward"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="[ +30 ]"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/podcast_next"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="[ NEXT ]"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/podcast_window_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="38dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:minWidth="160dp"
        android:paddingStart="12dp"
        android:paddingTop="2dp"
        android:paddingEnd="12dp"
        android:paddingBottom="2dp"
        android:text="PODCASTS"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/podcast_close"
        android:layout_width="48dp"
        android:layout_height="36dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="X"
        android:textSize="15sp" />

</FrameLayout>
